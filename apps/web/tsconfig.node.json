{
  // =========================================================================
  // Separate TypeScript config for Node-side files (build tooling).
  //
  // Vite config, Vitest config, and Playwright config run in Node.js,
  // not the browser. This config limits the lib to ES2022, enables
  // node types, and uses composite + emitDeclarationOnly so the
  // main tsconfig can reference it via project references without
  // emitting JS from the app sources.
  // =========================================================================
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist-node",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "playwright.config.ts"]
}
