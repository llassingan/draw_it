# ===== Dependencies =====
# pnpm virtual store — always gitignored
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ===== Build outputs =====
# Vite dev/dist, Next.js (legacy), and CI artifacts
.next/
out/
build/
dist/
dist-node/

# ===== TypeScript =====
# Incremental compilation caches
*.tsbuildinfo
next-env.d.ts

# ===== Debug logs =====
# Package manager and general log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ===== Environment =====
# Secrets and local overrides never committed
.env
.env*.local

# ===== Bun (alt runtime) =====
bun.lockb

# ===== Database (reserved for future use) =====
drizzle/
tmp/emails/

# ===== Editors / OS =====
# IDE configs and OS junk — per-developer, not shared
.vscode/
.idea/
*.swp
.DS_Store

# ===== Test artifacts =====
# Vitest coverage and Playwright output directories
coverage/
playwright-report/
test-results/

# ===== Runtime =====
# PIDs and logs from scripts/start.sh (background server orchestration)
.runtime/

# ===== Caches =====
# Local and Turbo build caches
.cache/
.turbo/

# ===== OpenCode / Sisyphus agent runtime =====
.opencode/
.sisyphus/
opencode.json
